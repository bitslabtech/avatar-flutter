# Normalize line endings — use LF in repository, auto-convert on checkout
* text=auto

# Force LF for scripts and source files
*.ts    text eol=lf
*.js    text eol=lf
*.dart  text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.sh    text eol=lf

# Force CRLF for Windows-specific files
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary files — no line-ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.pdf   binary
*.xlsx  binary
*.cdr   binary
